{
  "name": "anthropic-proxyandrebeasley2012workersdev",
  "main": "src/worker.js",
  "workers_dev": true,
  "preview_urls": false,
  "compatibility_date": "2026-03-16",
  "d1_databases": [
    {
      "binding": "INTAKE_DB",
